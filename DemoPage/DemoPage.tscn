[sub_resource type="Shader" id="Shader_txjb3"]
code = "shader_type canvas_item;

uniform vec2 blur_scale = vec2(8.0, 8.0); // max blur size
uniform vec4 color_modulate: source_color;
uniform sampler2D SCREEN_TEXTURE : hint_screen_texture, filter_linear;

const int SAMPLES = 8;

const float WEIGHTS[64] = float[](
    0.000008,0.000014,0.000022,0.000035,0.000054,0.000084,0.000127,0.000189,
    0.000279,0.000405,0.00058,0.00082,0.001141,0.001567,0.002121,0.002831,
    0.003726,0.004835,0.006186,0.007804,0.009708,0.011908,0.014402,0.017174,
    0.020194,0.023412,0.026764,0.030168,0.033529,0.036743,0.039703,0.042301,
    0.044438,0.046031,0.047013,0.047346,0.047013,0.046031,0.044438,0.042301,
    0.039703,0.036743,0.033529,0.030168,0.026764,0.023412,0.020194,0.017174,
    0.014402,0.011908,0.009708,0.007804,0.006186,0.004835,0.003726,0.002831,
    0.002121,0.001567,0.001141,0.00082,0.00058,0.000405,0.000279,0.000189
);

void fragment() {

    // This contains the CanvasItem modulate color
    vec4 canvas_modulate = COLOR;

    float alpha = smoothstep(0.0, 1.0, canvas_modulate.a);

    vec2 base_uv = SCREEN_UV;

    // Scale blur radius by alpha
    vec2 scale = SCREEN_PIXEL_SIZE * blur_scale * alpha;

    vec3 accum = vec3(0.0);
    float total_weight = 0.0;

    int half = SAMPLES / 2;

    for (int i = 0; i < SAMPLES; ++i) {
        int oi = i - half;
        for (int j = 0; j < SAMPLES; ++j) {
            int oj = j - half;

            int weight_index = i * SAMPLES + j;
            float w = WEIGHTS[weight_index];

            vec2 offset = scale * vec2(float(oi), float(oj));
            accum += texture(SCREEN_TEXTURE, base_uv + offset).rgb * w;
            total_weight += w;
        }
    }

    vec3 blurred = accum / max(total_weight, 0.00001);

    // Original screen color (for fade-in effect)
    vec3 original = texture(SCREEN_TEXTURE, base_uv).rgb;

    // Blend between original and blurred based on alpha
    vec3 final_color = mix(original, blurred, alpha);

    COLOR.rgb = final_color * color_modulate.rgb * canvas_modulate.rgb;

    // Use alpha for transparency fade
    COLOR.a = alpha * color_modulate.a;
}"

